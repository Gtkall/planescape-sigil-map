{
  "name": "planescape-sigil-map",
  "version": "1.0.0",
  "description": "An interactive map of Sigil from the Planescape Setting, ported to FoundryVTT.",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "watch": "vite build --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "fetch-data": "node scripts/fetch-map-data.mjs",
    "fetch-data:force": "node scripts/fetch-map-data.mjs --force",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "eslint": "^10.0.3",
    "eslint-plugin-sonarjs": "^4.0.2",
    "fvtt-types": "github:League-of-Foundry-Developers/foundry-vtt-types#main",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "semantic-release": "^25.0.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.0.0",
    "vite-plugin-static-copy": "^2.2.0"
  },
  "lint-staged": {
    "src/**/*.ts": "eslint"
  },
  "author": "Georgios Karettas",
  "license": "MIT"
}
